MAX_BINS = 140        # Number of bins in histogram

# Inlet “density” smoothing (cheap moving average)
SMOOTH_INLET = True
INLET_SMOOTH_WINDOW = 3  # odd integer >= 3  #In this example with value of 3, it means smoothing = (value in previous bin + value in current bin + value in next bin) / 3

# Routing curve smoothing (cheap moving average)
SMOOTH_P_CURVES = True
P_SMOOTH_WINDOW = 3       # odd integer >= 3
ISOTONIC_CURVES = True    # needs sklearn; This assures that the probability plots follow the concept of increase and decrease in probability. 

