TOL_S = 1e-6      #the EM algorithm stops when the exposures change by less than 0.0001%. It is a very strict convergence threshold.
SMOOTH_EVERY = 10       # only smooth/isotonic every N iterations
ALPHA_DIRICHLET = 1e-3  # pseudocount / prior strength  #a small pseudocount added to the outlets histogram counts to stabilize probability estimation and avoid zero count in some bins. It comes from the concept of a Dirichlet prior in Bayesian statistics.
C_FLOOR = 1e-9          # a small pseudocount added to the inlet histogram counts to stabilize probability estimation and avoid zero count in some bins.

