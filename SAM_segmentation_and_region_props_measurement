"""
Batch Otsu thresholding on PNG images + regionprops measurements.

Measures (per detected object):
- major_axis_length (px)
- minor_axis_length (px)
- area (px^2)
- circularity_custom = 4*area / (major_axis_length^2 * 3.14)

Saves one CSV in the same folder containing measured values, with an extra column "image_name".

Author: Elham
"""

from pathlib import Path
import numpy as np
import pandas as pd

from skimage import io, filters, measure, morphology, color

# =========================================================
# USER SETTINGS
# =========================================================
INPUT_DIR = Path(r"...\SAM_binary_masks_individual")  # Path to individual binary images
OUTPUT_CSV = INPUT_DIR / "measured_value.csv"

# Optional cleanup
MIN_AREA_PX = 5          # remove tiny specks
KEEP_LARGEST_ONLY = False # True if you expect only one object per image

# =========================================================
# HELPERS
# =========================================================
def read_grayscale(p: Path) -> np.ndarray:
    img = io.imread(str(p))
    if img.ndim == 3:
        img = color.rgb2gray(img)  # -> float in [0,1]
    else:
        # if uint8/uint16, normalize to [0,1] for Otsu stability
        img = img.astype(np.float32)
        if img.max() > 1.0:
            img /= img.max()
    return img

def otsu_mask(img01: np.ndarray) -> np.ndarray:
    thr = filters.threshold_otsu(img01)
    mask = img01 > thr  # works for white object on dark background (like your example)

    # If the mask accidentally selects the background (happens if image is inverted),
    # flip it so "True" is the smaller fraction.
    if mask.mean() > 0.5:
        mask = ~mask

    # Clean up
    mask = morphology.remove_small_objects(mask, min_size=MIN_AREA_PX)
    mask = morphology.remove_small_holes(mask, area_threshold=MIN_AREA_PX)

    return mask

def keep_largest_component(mask: np.ndarray) -> np.ndarray:
    lab = measure.label(mask)
    if lab.max() == 0:
        return mask
    props = measure.regionprops(lab)
    largest = max(props, key=lambda r: r.area).label
    return lab == largest

# =========================================================
# MAIN
# =========================================================
def main():
    if not INPUT_DIR.exists():
        raise FileNotFoundError(f"Folder not found:\n{INPUT_DIR}")

    png_files = sorted(INPUT_DIR.glob("*.png"))
    if not png_files:
        raise FileNotFoundError(f"No .png files found in:\n{INPUT_DIR}")

    rows = []

    for p in png_files:
        img = read_grayscale(p)
        mask = otsu_mask(img)

        if KEEP_LARGEST_ONLY:
            mask = keep_largest_component(mask)

        lab = measure.label(mask)
        props = measure.regionprops(lab)

        if len(props) == 0:
            # still write a row to show the image was processed
            rows.append({
                "image_name": p.name,
                "object_id": np.nan,
                "major_axis_length": np.nan,
                "minor_axis_length": np.nan,
                "area": 0,
                "circularity_custom": np.nan,
            })
            continue

        for r in props:
            major = float(r.major_axis_length) if r.major_axis_length else np.nan
            minor = float(r.minor_axis_length) if r.minor_axis_length else np.nan
            area = float(r.area)

            # Your custom circularity definition:
            # 4*area/(major_axis_length*major_axis_length*3.14)
            if np.isfinite(major) and major > 0:
                circ_custom = 4.0 * area / (major * major * 3.14)
            else:
                circ_custom = np.nan

            rows.append({
                "image_name": p.name,
                "object_id": int(r.label),
                "major_axis_length": major,
                "minor_axis_length": minor,
                "area": area,
                "circularity_custom": circ_custom,
            })

    df = pd.DataFrame(rows)
    df.to_csv(OUTPUT_CSV, index=False)
    print(f"Saved: {OUTPUT_CSV}")
    print(f"Rows (objects): {len(df)}")

if __name__ == "__main__":
    main()
