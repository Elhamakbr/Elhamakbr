#-------Part I: Image segmentation using SAM--------
import os
from glob import glob

import torch
import cv2
import numpy as np
from segment_anything import sam_model_registry, SamAutomaticMaskGenerator

# ---------------- USER SETTINGS ----------------
IMAGE_FOLDER = r"folder_path"
CHECKPOINT_PATH = r"...\sam_vit_h_4b8939.pth"
MODEL_TYPE = "vit_h"           # "vit_b", "vit_l", or "vit_h"
IMAGE_PATTERN = "*.tif"        # Change if you have .png, .jpg, etc.

MIN_AREA = 1                   # Ignore very small masks (pixels)
SAVE_INDIVIDUAL_MASKS = True   # Save each object as its own binary mask image
SAVE_COMBINED_MASK = True      # Save one combined binary mask per input image
# ------------------------------------------------


def init_sam_model(checkpoint_path, model_type):
    """Load SAM model on CPU or CUDA."""
    device = "cuda" if torch.cuda.is_available() else "cpu"
    print(f"Using device: {device}")
    sam = sam_model_registry[model_type](checkpoint=checkpoint_path)
    sam.to(device=device)
    mask_generator = SamAutomaticMaskGenerator(sam)
    return mask_generator


def save_binary_masks_from_image(image_path, mask_generator, out_individual_dir, out_combined_dir):
    """Run SAM segmentation and save binary mask images only."""
    image_name = os.path.basename(image_path)
    base_name, _ = os.path.splitext(image_name)

    # --- Read image and convert to RGB ---
    # --- Read image (keep bit-depth) ---
    image = cv2.imread(image_path, cv2.IMREAD_UNCHANGED)
    if image is None:
        print(f"Could not read {image_path}, skipping.")
        return
    
    # --- Convert 16-bit → 8-bit if needed ---
    if image.dtype == np.uint16:
        image = cv2.normalize(image, None, 0, 255, cv2.NORM_MINMAX).astype(np.uint8)
    
    # --- Ensure RGB ---
    if image.ndim == 2:  # grayscale
        image_rgb = cv2.cvtColor(image, cv2.COLOR_GRAY2RGB)
    else:
        image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)

    # --- Generate masks with SAM ---
    masks = mask_generator.generate(image_rgb)
    print(f"{image_name}: {len(masks)} masks detected")

    h, w = image_rgb.shape[:2]
    combined = np.zeros((h, w), dtype=np.uint8)
    kept = 0

    # --- Loop over masks and save binaries ---
    for idx, m in enumerate(masks):
        seg = m["segmentation"].astype(np.uint8)  # 0/1 mask

        if int(seg.sum()) < MIN_AREA:
            continue

        kept += 1

        # Convert to 0/255 binary
        bin_mask = (seg * 255).astype(np.uint8)

        # Accumulate combined mask (union)
        combined = cv2.bitwise_or(combined, bin_mask)

        # Save individual object mask
        if SAVE_INDIVIDUAL_MASKS:
            out_path = os.path.join(out_individual_dir, f"{base_name}_mask_{idx:03d}.png")
            cv2.imwrite(out_path, bin_mask)

    # Save combined mask for the whole image
    if SAVE_COMBINED_MASK and kept > 0:
        out_path = os.path.join(out_combined_dir, f"{base_name}_mask_combined.png")
        cv2.imwrite(out_path, combined)


def main():
    # 1) init SAM
    mask_generator = init_sam_model(CHECKPOINT_PATH, MODEL_TYPE)

    # 2) output folders
    individual_dir = os.path.join(IMAGE_FOLDER, "SAM_binary_masks_individual")
    combined_dir   = os.path.join(IMAGE_FOLDER, "SAM_binary_masks_combined")
    os.makedirs(individual_dir, exist_ok=True)
    os.makedirs(combined_dir, exist_ok=True)

    # 3) find images
    image_paths = sorted(glob(os.path.join(IMAGE_FOLDER, IMAGE_PATTERN)))
    print(f"\nFound {len(image_paths)} images in folder.\n")

    # 4) process each image
    for img_path in image_paths:
        save_binary_masks_from_image(
            img_path,
            mask_generator,
            out_individual_dir=individual_dir,
            out_combined_dir=combined_dir,
        )

    print("\nDone. Binary masks saved to:")
    print(f"  Individual masks: {individual_dir}")
    print(f"  Combined masks:   {combined_dir}")


if __name__ == "__main__":
    main()



